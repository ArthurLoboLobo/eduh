{
  "name": "eduh",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate": "node --env-file=.env.local node_modules/.bin/node-pg-migrate --database-url-var DATABASE_URL_UNPOOLED --migrations-dir db/migrations up",
    "migrate:test": "node --env-file=.env.test node_modules/.bin/node-pg-migrate --database-url-var DATABASE_URL_UNPOOLED --migrations-dir db/migrations up",
    "migrate:create": "node --env-file=.env.local node_modules/.bin/node-pg-migrate --migrations-dir db/migrations create",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/react": "^3.0.118",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@neondatabase/serverless": "^1.0.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vercel/blob": "^2.3.1",
    "ai": "^6.0.116",
    "geist": "^1.7.0",
    "jose": "^6.2.1",
    "katex": "^0.16.39",
    "next": "^16.2.4",
    "node-pg-migrate": "^8.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
