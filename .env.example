# Neon Postgres — pooled connection (used by the app at runtime)
# Auto-set by Neon integration on Vercel
DATABASE_URL=

# Neon Postgres — direct/non-pooled connection (used for migrations)
# Auto-set by Neon integration on Vercel
DATABASE_URL_UNPOOLED=

# Vercel Blob access token
# Auto-set by Vercel when you provision Blob
BLOB_READ_WRITE_TOKEN=

# Resend email service API key
# Get from: https://resend.com → API Keys
RESEND_API_KEY=

# Resend sender address
# Free tier: use onboarding@resend.dev (no domain verification needed)
# Production: use your verified domain, e.g. noreply@yourdomain.com
RESEND_FROM_EMAIL=

# Google Gemini API key (default env var for @ai-sdk/google)
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Secret for signing JWTs (random 32+ byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Admin email — user with this email can access /admin/ai-logs dashboard
ADMIN_EMAIL=

# AbacatePay API key
ABACATEPAY_API_KEY=

# AbacatePay webhook secret configured at the dashboard
ABACATEPAY_WEBHOOK_SECRET=